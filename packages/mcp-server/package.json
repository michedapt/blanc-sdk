{
  "name": "@blanc/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Blanc — a universal render surface. Send a spec, get a live page.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "blanc-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@json-render/core": "^0.16.0",
    "@json-render/next": "^0.16.0",
    "@json-render/react": "^0.16.0",
    "@json-render/shadcn": "^0.16.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "blanc",
    "mcp",
    "model-context-protocol",
    "render",
    "ui",
    "ai-agents"
  ],
  "license": "MIT"
}
